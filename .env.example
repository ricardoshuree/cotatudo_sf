# Variáveis de Ambiente Necessárias

# Chave do Google Gemini (Obrigatória)
# Obtenha em: https://aistudio.google.com/app/apikey
MY_API_KEY=

# Token de Acesso do Mercado Livre (Recomendado para evitar erro 403)
# Obtenha em: https://developers.mercadolivre.com.br/pt_br/autenticacao-e-autorizacao
ML_ACCESS_TOKEN=

# Chave da API Serper.dev (Google Shopping)
# Obtenha em: https://serper.dev
SERPER_API_KEY=
